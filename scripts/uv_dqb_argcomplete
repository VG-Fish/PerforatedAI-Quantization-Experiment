#!/usr/bin/env python3
"""Bridge argcomplete from ``uv run dqb`` to the ``dqb`` entry point.

argcomplete registers completions against the executable at the start of the
command line. For this project, that executable is often ``uv`` even though the
parser we want lives behind ``uv run dqb``. This script is meant to be used as an
external argcomplete script for ``uv``; it rewrites the completion environment so
the existing ``dqb`` parser sees the command line it expects.
"""

from __future__ import annotations

import os
import subprocess
import sys


UV_PREFIX = "uv run "
DQB_PREFIX = "uv run dqb"


def _completion_point() -> int:
    try:
        return int(os.environ.get("COMP_POINT", "0"))
    except ValueError:
        return 0


def main() -> int:
    comp_line = os.environ.get("COMP_LINE", "")
    comp_point = _completion_point()

    if not comp_line.startswith(DQB_PREFIX):
        return 1

    env = os.environ.copy()
    env["COMP_LINE"] = "dqb" + comp_line[len(DQB_PREFIX) :]
    env["COMP_POINT"] = str(max(0, comp_point - len(UV_PREFIX)))

    pass_fds = tuple(fd for fd in (8, 9) if _fd_is_open(fd))
    return subprocess.run(["uv", "run", "dqb"], env=env, check=False, pass_fds=pass_fds).returncode


def _fd_is_open(fd: int) -> bool:
    try:
        os.fstat(fd)
    except OSError:
        return False
    return True


if __name__ == "__main__":
    sys.exit(main())
